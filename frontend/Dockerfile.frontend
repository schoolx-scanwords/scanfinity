FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY next.config.ts ./
COPY tsconfig.json ./
COPY tailwind.config.js ./
COPY postcss.config.js ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

EXPOSE 3000

# This will be overridden by the command in docker-compose
CMD ["npm", "run", "dev"]