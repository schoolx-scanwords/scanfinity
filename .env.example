POSTGRES_USER=admin
POSTGRES_PASSWORD=12345
POSTGRES_DB=Scanfinity
POSTGRES_PORT=5432

# Optional but recommended
JWT_SECRET_KEY=change_me_please

# Email verification (recommended)
# Base URL of the site where users open the verification page
# Example: http://localhost:8000 (if FastAPI serves the built Next export)
EMAIL_VERIFY_BASE_URL=http://localhost:8000

# Secret used as a "pepper" when hashing verification tokens (change in production)
EMAIL_TOKEN_SECRET=change_me_please

# SMTP settings (optional for local dev; if missing, backend will print verification link to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Scanfinity
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=15
