# Postgres (used by docker-compose.yml and backend/app/database/connect.py)
POSTGRES_USER=scanfinity
POSTGRES_PASSWORD=scanfinity
POSTGRES_DB=scanfinity
POSTGRES_PORT=5432

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET_KEY=change_me_please
EMAIL_TOKEN_SECRET=change_me_please
EMAIL_VERIFY_BASE_URL=http://localhost:8000

# SMTP (optional; if not set, emails are printed to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Dev fallback: show verification link in UI even without SMTP.
# WARNING: do NOT enable this in production if you don't want tokens to be visible to the client.
EMAIL_EXPOSE_VERIFY_URL=true

# Frontend dev proxy (used in frontend/next.config.ts rewrites when NODE_ENV=development)
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
